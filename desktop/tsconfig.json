{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "forge.config.ts",
    "main/**/*.ts",
    "preload/**/*.ts",
    "scripts/**/*.mts",
    "scripts/**/*.ts"
  ]
}
